<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Printer Queue Simulator</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
}

body {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    color: #e2e8f0;
    min-height: 100vh;
}

/* HEADER */
header {
    padding: 20px 40px;
    font-size: 22px;
    font-weight: 600;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
}

/* LAYOUT */
.container {
    padding: 30px;
    max-width: 900px;
    margin: auto;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(18px);
    border-radius: 16px;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

/* INPUT */
input {
    width: 100%;
    padding: 12px;
    border-radius: 10px;
    border: none;
    margin-top: 10px;
    background: rgba(255,255,255,0.08);
    color: white;
}

/* BUTTONS */
button {
    padding: 12px;
    margin-top: 10px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(90deg, #22c55e, #4ade80);
    color: black;
    font-weight: 600;
    cursor: pointer;
}

button:hover {
    transform: scale(1.05);
}

.process {
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
}

.clear {
    background: linear-gradient(90deg, #ef4444, #f87171);
}

/* QUEUE */
.queue {
    margin-top: 20px;
    display: flex;
    gap: 10px;
    overflow-x: auto;
}

.job {
    min-width: 120px;
    padding: 15px;
    border-radius: 12px;
    background: rgba(255,255,255,0.08);
    text-align: center;
    transition: 0.3s;
}

.job:first-child {
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
}

/* CURRENT */
.current {
    margin-top: 20px;
    padding: 15px;
    border-radius: 12px;
    background: rgba(34,197,94,0.2);
    text-align: center;
    font-weight: 500;
}

/* EMPTY */
.empty {
    margin-top: 15px;
    text-align: center;
    color: #94a3b8;
}

</style>
</head>

<body>

<header>🖨 Printer Queue (FIFO Simulation)</header>

<div class="container">
    <div class="card">

        <h3>Add Print Job</h3>
        <input type="text" id="jobName" placeholder="Enter document name">

        <button onclick="addJob()">Add Job</button>
        <button class="process" onclick="processJob()">Print Next</button>
        <button class="clear" onclick="clearQueue()">Clear Queue</button>

        <div class="current" id="currentJob">
            No job printing
        </div>

        <div id="queueContainer" class="queue"></div>
        <div id="emptyMsg" class="empty">Queue is empty</div>

    </div>
</div>

<script>
class Queue {
    constructor() {
        this.items = [];
    }

    enqueue(item) {
        this.items.push(item);
    }

    dequeue() {
        return this.items.shift();
    }

    peek() {
        return this.items[0];
    }

    isEmpty() {
        return this.items.length === 0;
    }

    clear() {
        this.items = [];
    }
}

const printerQueue = new Queue();
let printing = false;

/* ADD JOB */
function addJob() {
    const name = document.getElementById("jobName").value;
    if (!name) return;

    printerQueue.enqueue(name);
    document.getElementById("jobName").value = "";
    render();
}

/* PROCESS JOB */
function processJob() {
    if (printing || printerQueue.isEmpty()) return;

    printing = true;
    const job = printerQueue.peek();

    document.getElementById("currentJob").innerText =
        "Printing: " + job + "...";

    setTimeout(() => {
        printerQueue.dequeue();
        printing = false;
        render();
    }, 2000); // simulate delay
}

/* CLEAR */
function clearQueue() {
    printerQueue.clear();
    render();
}

/* RENDER */
function render() {
    const container = document.getElementById("queueContainer");
    const emptyMsg = document.getElementById("emptyMsg");
    const currentDiv = document.getElementById("currentJob");

    container.innerHTML = "";

    if (printerQueue.isEmpty()) {
        emptyMsg.style.display = "block";
        currentDiv.innerText = "No job printing";
        return;
    }

    emptyMsg.style.display = "none";

    printerQueue.items.forEach((job, index) => {
        const div = document.createElement("div");
        div.className = "job";
        div.innerText = job;

        container.appendChild(div);
    });

    if (!printing) {
        currentDiv.innerText =
            "Next Job: " + printerQueue.peek();
    }
}
</script>

</body>
</html>
