<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Advanced Shopping Cart</title>
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: linear-gradient(135deg, #eef2ff, #fdf4ff);
    min-height: 100vh;
}

/* HEADER */
header {
    background: linear-gradient(90deg, #4f46e5, #7c3aed);
    color: white;
    padding: 22px 40px;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

/* LAYOUT */
.container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
    padding: 30px;
}

/* CARD */
.card {
    background: #ffffff;
    padding: 22px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: transform 0.2s ease;
}

.card:hover {
    transform: translateY(-3px);
}

/* HEADINGS */
h3 {
    margin-bottom: 10px;
    color: #1e293b;
}

/* INPUTS */
input, select {
    width: 100%;
    padding: 11px;
    margin-top: 10px;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    transition: 0.2s;
}

input:focus, select:focus {
    border-color: #6366f1;
    outline: none;
    background: #fff;
}

/* BUTTONS */
button {
    width: 100%;
    padding: 12px;
    margin-top: 12px;
    border-radius: 10px;
    border: none;
    background: linear-gradient(90deg, #6366f1, #7c3aed);
    color: white;
    font-weight: 500;
    cursor: pointer;
    transition: 0.25s;
}

button:hover {
    transform: scale(1.02);
    box-shadow: 0 5px 15px rgba(99,102,241,0.4);
}

/* DANGER BUTTON */
.danger {
    background: linear-gradient(90deg, #ef4444, #dc2626);
}

.danger:hover {
    box-shadow: 0 5px 15px rgba(239,68,68,0.4);
}

/* CART ITEMS */
.cart-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f1f5f9;
    padding: 12px 14px;
    border-radius: 10px;
    margin-top: 10px;
    transition: 0.2s;
}

.cart-item:hover {
    background: #e0e7ff;
}

/* SUMMARY */
.summary {
    margin-top: 18px;
    font-weight: 600;
    font-size: 16px;
    color: #1e293b;
}

/* EMPTY STATE */
.empty {
    text-align: center;
    color: #94a3b8;
    margin-top: 20px;
}

/* RESPONSIVE */
@media(max-width: 800px) {
    .container {
        grid-template-columns: 1fr;
    }
}
</style>
</head>
<body>

<header>🛒 My Shopping Cart</header>

<div class="container">

    <!-- ADD PRODUCT -->
    <div class="card">
        <h3>Add Product</h3>

        <input type="text" id="name" placeholder="Product Name">
        <input type="number" id="price" placeholder="Price">
        <input type="number" id="qty" placeholder="Quantity">

        <select id="position">
            <option value="head">Insert at Head</option>
            <option value="tail">Insert at Tail</option>
        </select>

        <button onclick="addItem()">Add to Cart</button>
    </div>

    <!-- CART DISPLAY -->
    <div class="card">
        <h3>Your Cart</h3>

        <input type="number" id="removeId" placeholder="Enter ID to remove">
        <button class="danger" onclick="removeItem()">Remove Item</button>
        <button onclick="clearCart()">Clear Cart</button>

        <div id="cartList"></div>

        <div class="summary" id="summary"></div>
    </div>

</div>

<script>
class Node {
    constructor(id, name, price, qty) {
        this.id = id;
        this.name = name;
        this.price = price;
        this.qty = qty;
        this.next = null;
    }
}

class LinkedList {
    constructor() {
        this.head = null;
        this.tail = null;
        this.counter = 1;
    }

    insertAtHead(name, price, qty) {
        const node = new Node(this.counter++, name, price, qty);

        if (!this.head) {
            this.head = this.tail = node;
        } else {
            node.next = this.head;
            this.head = node;
        }
    }

    insertAtTail(name, price, qty) {
        const node = new Node(this.counter++, name, price, qty);

        if (!this.tail) {
            this.head = this.tail = node;
        } else {
            this.tail.next = node;
            this.tail = node;
        }
    }

    removeById(id) {
        if (!this.head) return;

        if (this.head.id == id) {
            this.head = this.head.next;
            if (!this.head) this.tail = null;
            return;
        }

        let curr = this.head;
        while (curr.next && curr.next.id != id) {
            curr = curr.next;
        }

        if (curr.next) {
            if (curr.next === this.tail) {
                this.tail = curr;
            }
            curr.next = curr.next.next;
        }
    }

    clear() {
        this.head = this.tail = null;
    }

    getAll() {
        let arr = [];
        let curr = this.head;
        let total = 0;
        let count = 0;

        while (curr) {
            arr.push(curr);
            total += curr.price * curr.qty;
            count += curr.qty;
            curr = curr.next;
        }

        return { arr, total, count };
    }
}

const cart = new LinkedList();

/* ACTIONS */
function addItem() {
    const name = document.getElementById("name").value;
    const price = Number(document.getElementById("price").value);
    const qty = Number(document.getElementById("qty").value);
    const pos = document.getElementById("position").value;

    if (!name || price <= 0 || qty <= 0) {
        alert("Enter valid values");
        return;
    }

    if (pos === "head") {
        cart.insertAtHead(name, price, qty);
    } else {
        cart.insertAtTail(name, price, qty);
    }

    render();
}

function removeItem() {
    const id = document.getElementById("removeId").value;
    cart.removeById(id);
    render();
}

function clearCart() {
    cart.clear();
    render();
}

/* RENDER */
function render() {
    const { arr, total, count } = cart.getAll();
    const container = document.getElementById("cartList");
    const summary = document.getElementById("summary");

    container.innerHTML = "";

    if (arr.length === 0) {
        container.innerHTML = "<div class='empty'>Cart is empty</div>";
        summary.innerHTML = "";
        return;
    }

    arr.forEach(item => {
        const div = document.createElement("div");
        div.className = "cart-item";
        div.innerHTML = `
            <span>#${item.id} ${item.name} (x${item.qty})</span>
            <span>₹${item.price * item.qty}</span>
        `;
        container.appendChild(div);
    });

    summary.innerHTML = `
        Items: ${count} <br>
        Total: ₹${total}
    `;
}
</script>

</body>
</html>
