<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advanced Library System</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:radial-gradient(circle at top,#020617,#020617 30%,#0f172a);
  color:white;
  padding:20px;
  overflow-x:hidden;
}

h1{
  text-align:center;
  margin-bottom:30px;
  font-weight:600;
  letter-spacing:1px;
  background:linear-gradient(90deg,#38bdf8,#818cf8);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.container{
  max-width:950px;
  margin:auto;
}

.card{
  background:rgba(255,255,255,0.06);
  backdrop-filter:blur(15px);
  border:1px solid rgba(255,255,255,0.12);
  padding:25px;
  border-radius:18px;
  margin-bottom:25px;
  box-shadow:0 10px 40px rgba(0,0,0,0.4);
  transition:all 0.3s ease;
  position:relative;
}

.card::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:18px;
  background:linear-gradient(120deg,transparent,#38bdf833,transparent);
  opacity:0;
  transition:0.3s;
}

.card:hover::before{opacity:1;}
.card:hover{transform:translateY(-5px) scale(1.01);}

h3{
  margin-bottom:12px;
  font-weight:500;
  color:#e2e8f0;
}

input, select{
  width:100%;
  padding:12px;
  margin:10px 0;
  border-radius:10px;
  border:none;
  background:#1e293b;
  color:white;
  transition:0.3s;
}

input:focus, select:focus{
  outline:none;
  box-shadow:0 0 0 2px #38bdf8;
}

input::placeholder{color:#94a3b8;}

button{
  padding:10px 18px;
  margin-top:10px;
  border:none;
  border-radius:10px;
  background:linear-gradient(135deg,#38bdf8,#6366f1);
  color:white;
  font-weight:600;
  cursor:pointer;
  transition:all 0.25s ease;
}

button:hover{
  transform:translateY(-2px) scale(1.05);
  box-shadow:0 8px 25px rgba(99,102,241,0.5);
}

.book{
  background:rgba(255,255,255,0.08);
  padding:14px 16px;
  border-radius:12px;
  margin-top:12px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  transition:all 0.3s ease;
  border:1px solid transparent;
}

.book:hover{
  background:rgba(255,255,255,0.12);
  border-color:#38bdf8;
  transform:translateX(5px);
}

.tag{
  font-size:11px;
  background:linear-gradient(135deg,#38bdf8,#818cf8);
  color:#000;
  padding:4px 8px;
  border-radius:6px;
  margin-left:8px;
  font-weight:600;
}

.book div button{
  margin-left:6px;
  padding:6px 10px;
  font-size:12px;
}

.empty{
  text-align:center;
  opacity:0.6;
  margin-top:10px;
  font-size:14px;
}

@media(max-width:600px){
  .book{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
  }
}

</style>
</head>

<body>

<h1>📚 Advanced Library System</h1>

<div class="container">

<div class="card">
  <h3>Add / Edit Book</h3>
  <input id="title" placeholder="Book Title">
  <input id="author" placeholder="Author">
  <select id="category">
    <option>Fiction</option>
    <option>Technology</option>
    <option>Education</option>
  </select>
  <button onclick="addOrUpdateBook()">Save Book</button>
</div>

<div class="card">
  <h3>Search Book</h3>
  <input id="search" placeholder="Search by Title" onkeyup="searchBook()">
</div>

<div class="card">
  <h3>Book List (Max 5)</h3>
  <div id="bookList"></div>
</div>

</div>

<script>
const capacity = 5;
let books = JSON.parse(localStorage.getItem('books')) || [];
let editId = null;

function addOrUpdateBook(){
  const title = document.getElementById('title').value;
  const author = document.getElementById('author').value;
  const category = document.getElementById('category').value;

  if(!title || !author){
    alert('Fill all fields');
    return;
  }

  if(editId){
    books = books.map(b => b.id === editId ? {...b,title,author,category} : b);
    editId = null;
  } else {
    if(books.length >= capacity){
      alert('Library Full');
      return;
    }
    books.push({id: Date.now(), title, author, category});
  }

  saveData();
  clearInputs();
  displayBooks(books);
}

function removeBook(id){
  books = books.filter(b => b.id !== id);
  saveData();
  displayBooks(books);
}

function editBook(id){
  const book = books.find(b => b.id === id);
  document.getElementById('title').value = book.title;
  document.getElementById('author').value = book.author;
  document.getElementById('category').value = book.category;
  editId = id;
}

function searchBook(){
  const query = document.getElementById('search').value.toLowerCase();
  const filtered = books.filter(b => b.title.toLowerCase().includes(query));
  displayBooks(filtered);
}

function displayBooks(list){
  const container = document.getElementById('bookList');
  container.innerHTML = '';

  if(list.length===0){
    container.innerHTML = '<div class="empty">No books found 📭</div>';
    return;
  }

  list.forEach(book => {
    const div = document.createElement('div');
    div.className = 'book';
    div.innerHTML = `
      <span>${book.title} - ${book.author} <span class="tag">${book.category}</span></span>
      <div>
        <button onclick="editBook(${book.id})">Edit</button>
        <button onclick="removeBook(${book.id})">Remove</button>
      </div>
    `;
    container.appendChild(div);
  });
}

function saveData(){
  localStorage.setItem('books', JSON.stringify(books));
}

function clearInputs(){
  document.getElementById('title').value='';
  document.getElementById('author').value='';
}

window.onload = () => displayBooks(books);
</script>

</body>
</html>
